{
    "name": "kqueue/kqueue",
    "description": "A production-grade, non-blocking queue runtime for Laravel — powered by Swoole coroutines",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "queue", "swoole", "coroutine", "async", "non-blocking", "concurrent", "runtime"],
    "homepage": "https://github.com/kunalGhoshOne/kqueue",
    "authors": [
        {
            "name": "Kunal Ghosh",
            "email": "kunalghosh10000@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/kunalGhoshOne/kqueue/issues",
        "source": "https://github.com/kunalGhoshOne/kqueue"
    },
    "require": {
        "php": "^8.1",
        "ext-swoole": "^5.0|^6.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "illuminate/console": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "KQueue\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KQueue\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KQueue\\KQueueServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
